# ─────────────────────────────────────────────────────
#  EMS Environment Configuration Template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ems
DB_USER=ems_user
DB_PASSWORD=

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=15m

# HashiCorp Vault (optional — used in secrets management module)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=

# Logging
LOG_LEVEL=info
